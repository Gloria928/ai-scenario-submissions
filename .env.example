# AI场景编程作业提交系统 - 环境变量配置
# 专为Gloria928定制 - 60人课堂，每周Python作业

# ====================
# GitHub配置（必需）
# ====================

# GitHub Personal Access Token
# 权限：repo, workflow, issues
# 创建：https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub仓库信息
GITHUB_OWNER=Gloria928
GITHUB_REPO=ai-scenario-submissions

# ====================
# 服务器配置
# ====================

# 服务端口
PORT=3000

# 运行环境
NODE_ENV=production

# ====================
# 前端集成配置
# ====================

# 前端地址（用于CORS配置）
# 你的Gitee教材页面地址
FRONTEND_URL=https://gitee.com/your-username/your-textbook-page

# ====================
# 课堂规模配置
# ====================

# 学生人数
MAX_STUDENTS=60

# 提交频率限制（次/15分钟）
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# 代码长度限制（字符）
MAX_CODE_LENGTH=5000
MIN_CODE_LENGTH=10

# 数据保留时间（毫秒）
DATA_RETENTION_MS=86400000  # 24小时

# 缓存时间（毫秒）
CACHE_TTL_MS=300000  # 5分钟

# ====================
# 安全配置
# ====================

# 是否启用详细错误信息（生产环境建议false）
SHOW_DETAILED_ERRORS=false

# 请求超时时间（毫秒）
REQUEST_TIMEOUT_MS=30000

# ===================